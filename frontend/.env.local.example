# Frontend Environment Variables Template
# Copy this file to .env.local and fill in your values
# DO NOT COMMIT .env.local to git

# ============================================================
# DEVELOPMENT ENVIRONMENT
# ============================================================

# Site Configuration
# URL where your frontend is running
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API Configuration
# Point to your backend API server
NEXT_PUBLIC_API_URL=http://localhost:4000

# Debug Mode
# Set to true for development, false for production
NEXT_PUBLIC_DEBUG=true

# ============================================================
# PRODUCTION ENVIRONMENT (deploy to Vercel)
# ============================================================

# For production, set these as Vercel Environment Variables:
# 1. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
# 2. Add these variables:
#    - NEXT_PUBLIC_SITE_URL: https://yourdomain.com
#    - NEXT_PUBLIC_API_URL: https://api.yourdomain.com
#    - NEXT_PUBLIC_DEBUG: false

# ============================================================
# Notes
# ============================================================

# - NEXT_PUBLIC_* variables are exposed to the browser (visible in HTML)
# - Never put secrets here - use Vercel's hidden environment variables
# - Vercel CLI automatically manages VERCEL_OIDC_TOKEN (don't add manually)
# - Always use HTTPS URLs in production
