# Frontend Environment Variables Template
# Copy this file to .env.local and fill in your values
# DO NOT COMMIT .env.local to git

# ============================================================
# DEVELOPMENT ENVIRONMENT
# ============================================================

# Site Configuration
# URL where your frontend is running
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API Configuration
# Point to your backend API server
NEXT_PUBLIC_API_URL=http://localhost:4000

# Debug Mode
# Set to true for development, false for production
NEXT_PUBLIC_DEBUG=true

# ============================================================
# PRODUCTION ENVIRONMENT (deploy frontend to Render, backend to Railway)
# ============================================================

# For production, set these as Render environment variables:
# 1. Go to Render Dashboard → Your Web Service → Environment
# 2. Add these variables:
#    - NEXT_PUBLIC_SITE_URL: https://your-frontend.onrender.com
#    - NEXT_PUBLIC_API_URL: https://your-backend.railway.app
#    - NEXT_PUBLIC_DEBUG: false

# ============================================================
# Notes
# ============================================================

# - NEXT_PUBLIC_* variables are exposed to the browser (visible in HTML)
# - Never put secrets here - use your platform's secret environment variables
# - Always use HTTPS URLs in production
