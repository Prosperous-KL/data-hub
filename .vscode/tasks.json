			"command": "cmd",
			"args": [
				"/c",
				"cd backend && npm install && npm test"
			],
			"isBackground": false
		},
		{
			"label": "full-end-to-end-test",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cd backend && npm install && npm test && cd ..\\frontend && npm install && npx playwright install && npm run test:e2e"
			],
			"isBackground": false
		},
		{
			"label": "git-init",
			"type": "shell",
			"command": "git",
			"args": [
				"init"
			],
			"isBackground": false
		},
		{
			"label": "git-untrack-node_modules",
			"type": "shell",
			"command": "git",
			"args": [
				"rm",
				"-r",
				"--cached",
				"backend/node_modules",
				"frontend/node_modules"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "untrack node_modules from git index",
			"type": "shell",
			"command": "git",
			"args": [
				"rm",
				"-r",
				"--cached",
				"--",
