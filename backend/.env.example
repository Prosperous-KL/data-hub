# Environment Configuration
NODE_ENV=development
PORT=4000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/prosperous_data_hub_db

# JWT Authentication
JWT_SECRET=your-secure-random-secret-key-min-32-characters
JWT_EXPIRES_IN=7d

# CORS Configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Application Base URL
APP_BASE_URL=http://localhost:4000

# Email Configuration (Gmail SMTP)
SMTP_GMAIL_USER=your-email@gmail.com
SMTP_GMAIL_APP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=Prosperous Data Hub

# SMS OTP Delivery (Hubtel)
HUBTEL_SMS_BASE_URL=https://smsc.hubtel.com/v1/messages/send
HUBTEL_SMS_CLIENT_ID=your_hubtel_client_id
HUBTEL_SMS_CLIENT_SECRET=your_hubtel_client_secret
HUBTEL_SMS_FROM=YourBrand

# Payment Provider Selection
PAYMENT_PROVIDER=SIMULATED
PAYMENT_CALLBACK_TOKEN=your-secure-callback-token
PAYMENT_CALLBACK_PROVIDER=AUTO

# Hubtel Payment Configuration
HUBTEL_CLIENT_ID=your_hubtel_client_id
HUBTEL_CLIENT_SECRET=your_hubtel_client_secret
HUBTEL_SIGNING_SECRET=your_hubtel_signing_secret
HUBTEL_BASE_URL=https://api.hubtel.com

# VTU Provider Configuration
VTU_PROVIDER=SIMULATED
VTU_API_KEY=your_vtu_api_key
VTU_BASE_URL=https://your-vtu-provider.com
VTU_SIMULATE_FAILURE_SUFFIX=

# Admin Configuration
ADMIN_EMAIL=admin@example.com

# Optional: WhatsApp/Twilio Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Optional: Google OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_TOKENINFO_URL=https://oauth2.googleapis.com/tokeninfo

# Optional: MTN Payment Configuration
MTN_ENV=sandbox
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_COLLECTION_PRIMARY_KEY=
MTN_COLLECTION_USER_ID=
MTN_COLLECTION_API_KEY=
MTN_COLLECTION_SUBSCRIPTION_KEY=
MTN_TARGET_ENV=sandbox
MTN_CURRENCY=GHS

# Optional: ExpressPay Configuration
EXPRESSPAY_API_KEY=
EXPRESSPAY_SIGNING_SECRET=
EXPRESSPAY_BASE_URL=

# Optional: Paystack Configuration
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=GHS
