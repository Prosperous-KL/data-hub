PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/test_db
JWT_SECRET=my_super_secret_key123
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,https://your-frontend-domain.vercel.app
APP_BASE_URL=http://localhost:4000

# Email Configuration (Gmail SMTP for OTP delivery)
SMTP_GMAIL_USER=your-email@gmail.com
SMTP_GMAIL_APP_PASSWORD=your_app_specific_password_from_gmail
SMTP_FROM_NAME=Prosperous Data Hub

# SMS Configuration (Hubtel for OTP and SMS verification)
# Get these credentials from https://portal.hubtel.com
HUBTEL_SMS_BASE_URL=https://smsc.hubtel.com/v1/messages/send
HUBTEL_SMS_CLIENT_ID=your_hubtel_sms_client_id
HUBTEL_SMS_CLIENT_SECRET=your_hubtel_sms_client_secret
HUBTEL_SMS_FROM=Prosperous

# Payment Provider Configuration (Options: SIMULATED, MTN, HUBTEL, EXPRESSPAY)
PAYMENT_PROVIDER=SIMULATED

# Hubtel Payment Configuration (if using HUBTEL as payment provider)
HUBTEL_CLIENT_ID=your_hubtel_payment_client_id
HUBTEL_CLIENT_SECRET=your_hubtel_payment_client_secret
HUBTEL_SIGNING_SECRET=your_hubtel_payment_signing_secret
HUBTEL_BASE_URL=https://api.hubtel.com/charges/initiate

# Express Pay Configuration
EXPRESSPAY_API_KEY=
EXPRESSPAY_SIGNING_SECRET=
EXPRESSPAY_BASE_URL=

# Payment Callbacks
PAYMENT_CALLBACK_TOKEN=myPaymentSecretKey123
PAYMENT_CALLBACK_PROVIDER=AUTO
HUBTEL_CALLBACK_SECRET=
EXPRESSPAY_CALLBACK_SECRET=

# VTU Provider Configuration
VTU_PROVIDER=SIMULATED
VTU_API_KEY=
VTU_BASE_URL=
VTU_SIMULATE_FAILURE_SUFFIX=

# Admin Email
ADMIN_EMAIL=admin@prosperoushub.com

# Notes:
# - On Render, APP_BASE_URL falls back to RENDER_EXTERNAL_URL if not set.
# - PAYMENT_CALLBACK_TOKEN and ADMIN_EMAIL now have safe defaults, but set explicit production values.
# - Set VTU_SIMULATE_FAILURE_SUFFIX only when you want the simulator to fail matching recipient numbers.
# - For SMS/OTP delivery, configure HUBTEL_SMS_* credentials at https://portal.hubtel.com
# - SMS verification requires HUBTEL_SMS_CLIENT_ID, HUBTEL_SMS_CLIENT_SECRET, and HUBTEL_SMS_FROM
