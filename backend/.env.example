PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/test_db
JWT_SECRET=my_super_secret_key123
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,https://your-frontend-domain.vercel.app
APP_BASE_URL=http://localhost:4000

# Email OTP delivery
SMTP_GMAIL_USER=your-email@gmail.com
SMTP_GMAIL_APP_PASSWORD=your_app_specific_password_from_gmail
SMTP_FROM_NAME=Prosperous Data Hub

# SMS OTP delivery (Hubtel)
HUBTEL_SMS_BASE_URL=https://smsc.hubtel.com/v1/messages/send
HUBTEL_SMS_CLIENT_ID=your_hubtel_sms_client_id
HUBTEL_SMS_CLIENT_SECRET=your_hubtel_sms_client_secret
HUBTEL_SMS_FROM=Prosperous

# Payment provider
PAYMENT_PROVIDER=SIMULATED

# Hubtel payment configuration
HUBTEL_CLIENT_ID=your_hubtel_payment_client_id
HUBTEL_CLIENT_SECRET=your_hubtel_payment_client_secret
HUBTEL_BASE_URL=https://api.hubtel.com/charges/initiate

# Payment callbacks
PAYMENT_CALLBACK_TOKEN=myPaymentSecretKey123
PAYMENT_CALLBACK_PROVIDER=AUTO
# VTU provider
VTU_PROVIDER=SIMULATED
VTU_API_KEY=
VTU_BASE_URL=
VTU_SIMULATE_FAILURE_SUFFIX=

# Admin
ADMIN_EMAIL=admin@prosperoushub.com
