# Environment Configuration (example placeholders)
# IMPORTANT: Do NOT commit real secrets to the repository.
# Use the hosting platform's secret management (Neon/Render/Railway) and
# keep a local `.env` only for development.

NODE_ENV=production
PORT=4000
BACKEND_URL=https://your-backend-url.example

# Database Configuration (Neon)
# Example: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://<username>:<password>@<host>/<db>?sslmode=require

# JWT Configuration
JWT_SECRET=REPLACE_WITH_A_STRONG_SECRET_OF_32_CHARS_MIN
JWT_EXPIRES_IN=7d

# CORS Configuration (comma separated)
CORS_ORIGIN=https://your-frontend.example

# Application URLs
APP_BASE_URL=https://your-frontend.example

# Payment provider and callback token
PAYMENT_PROVIDER=SIMULATED
PAYMENT_CALLBACK_TOKEN=REPLACE_WITH_SECURE_TOKEN
PAYMENT_CALLBACK_PROVIDER=AUTO

# Optional provider keys (leave blank if not used in production)
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SIGNING_SECRET=
HUBTEL_BASE_URL=https://api.hubtel.com

VTU_PROVIDER=SIMULATED
VTU_API_KEY=
VTU_BASE_URL=

# Email Configuration (optional)
SMTP_GMAIL_USER=
SMTP_GMAIL_APP_PASSWORD=
SMTP_FROM_NAME=Prosperous Data Hub

ADMIN_EMAIL=admin@yourdomain.example
