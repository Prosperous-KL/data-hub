# Environment Configuration (example placeholders)
# IMPORTANT: Do NOT commit real secrets to the repository.
# Use the hosting platform's secret management (Neon/Render/Railway) and
# keep a local `.env` only for development.

NODE_ENV=production
PORT=4000
BACKEND_URL=https://your-backend-url.example

# Database Configuration (Neon)
# Example: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://<username>:<password>@<host>/<db>?sslmode=require
# JWT Configuration
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32
JWT_EXPIRES_IN=7d

# CORS Configuration (comma separated)
CORS_ORIGIN=https://your-frontend.onrender.com

# Application URLs
APP_BASE_URL=https://your-backend.railway.app

# Payment provider and callback token
PAYMENT_PROVIDER=PAYSTACK
PAYMENT_CALLBACK_TOKEN=REPLACE_WITH_SECURE_TOKEN
PAYMENT_CALLBACK_PROVIDER=PAYSTACK

# Paystack payment configuration
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=GHS

VTU_PROVIDER=REAL
VTU_API_KEY=your_vtu_api_key
VTU_BASE_URL=https://your-vtu-provider.com

# SMS OTP Delivery (Hubtel)
HUBTEL_SMS_BASE_URL=https://smsc.hubtel.com/v1/messages/send
HUBTEL_SMS_CLIENT_ID=
HUBTEL_SMS_CLIENT_SECRET=
HUBTEL_SMS_FROM=Prosperous

# Email Configuration (optional)
SMTP_GMAIL_USER=your-email@gmail.com
SMTP_GMAIL_APP_PASSWORD=your_gmail_app_password
SMTP_FROM_NAME=Prosperous Data Hub

ADMIN_EMAIL=admin@example.com
