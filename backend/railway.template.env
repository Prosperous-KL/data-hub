# Railway environment template for backend service
# Copy values into Railway environment variables (do NOT commit secrets)

NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://<username>:<password>@<host>/<db>?sslmode=require
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://your-frontend.example
APP_BASE_URL=https://your-backend.example

# Payment
PAYMENT_PROVIDER=PAYSTACK
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYMENT_CALLBACK_PROVIDER=PAYSTACK
PAYMENT_CALLBACK_TOKEN=

# Hubtel SMS
HUBTEL_SMS_BASE_URL=https://smsc.hubtel.com/v1/messages/send
HUBTEL_SMS_CLIENT_ID=
HUBTEL_SMS_CLIENT_SECRET=
HUBTEL_SMS_FROM=YourBrand

# Hubtel Payment (optional)
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SIGNING_SECRET=
HUBTEL_BASE_URL=https://api.hubtel.com

# Email (optional)
SMTP_GMAIL_USER=
SMTP_GMAIL_APP_PASSWORD=
SMTP_FROM_NAME=Prosperous Data Hub

ADMIN_EMAIL=admin@yourdomain.example
